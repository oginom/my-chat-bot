# Worker name + D1 database name. Must be unique within your Cloudflare account.
# Used as both the Worker name and the D1 database name (kept in sync for simplicity).
PROJECT_NAME=my-chat-bot

# Cloudflare D1 database ID.
# Get this from `pnpm d1:create` output.
CF_D1_DATABASE_ID=

# Cloudflare KV namespace ID for LINE profile cache (24h TTL).
# Get this from `pnpm exec wrangler kv namespace create PROFILE_CACHE` output.
CF_KV_PROFILE_CACHE_ID=

# Master encryption key (32 bytes, base64). Generate with `pnpm keygen`.
# Used both by CLI scripts (to encrypt API keys before writing to D1)
# and the Worker (set it as a Secret via `pnpm exec wrangler secret put ENCRYPTION_KEY`).
ENCRYPTION_KEY=
