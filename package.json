{
  "name": "my-chat-bot",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@10.33.0",
  "engines": {
    "node": "22.22.2",
    "pnpm": "10.33.0"
  },
  "scripts": {
    "dev": "pnpm gen:config && wrangler dev",
    "cf:deploy": "pnpm gen:config && wrangler deploy",
    "typecheck": "tsc --noEmit",
    "gen:config": "tsx --env-file-if-exists=.env scripts/gen-wrangler-config.ts",
    "d1:create": "CF_D1_DATABASE_ID=00000000-0000-0000-0000-000000000000 pnpm gen:config && tsx --env-file-if-exists=.env scripts/d1.ts create",
    "db:migrate:local": "pnpm gen:config && tsx --env-file-if-exists=.env scripts/d1.ts migrate --local",
    "db:migrate:remote": "pnpm gen:config && tsx --env-file-if-exists=.env scripts/d1.ts migrate --remote",
    "bot:create": "pnpm gen:config && tsx --env-file-if-exists=.env scripts/create-bot.ts",
    "bot:list": "pnpm gen:config && tsx --env-file-if-exists=.env scripts/list-bots.ts",
    "bot:delete": "pnpm gen:config && tsx --env-file-if-exists=.env scripts/delete-bot.ts",
    "bot:set-key": "pnpm gen:config && tsx --env-file-if-exists=.env scripts/set-bot-key.ts",
    "bot:edit": "pnpm gen:config && tsx --env-file-if-exists=.env scripts/edit-bot.ts",
    "bot:add-platform": "pnpm gen:config && tsx --env-file-if-exists=.env scripts/add-platform.ts",
    "keygen": "tsx scripts/keygen.ts"
  },
  "dependencies": {
    "hono": "4.12.14"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "4.20260421.1",
    "@types/node": "22.19.17",
    "tsx": "4.21.0",
    "typescript": "5.7.2",
    "wrangler": "4.84.0"
  },
  "pnpm": {
    "onlyBuiltDependencies": ["esbuild", "workerd"]
  }
}
